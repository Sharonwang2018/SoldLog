# Copy to `.env.e2e` (gitignored) or add these keys to `.env.local`.
# Use a real Supabase user with email+password sign-in (no pending email confirmation).
# Supabase → Authentication → URL Configuration must allow http://127.0.0.1:3333 (Playwright dev port).
#
# Never put real passwords in this file — it is meant to be committed as a template only.

E2E_TEST_EMAIL=
E2E_TEST_PASSWORD=

# Optional: slug already owned by another profile (duplicate-handle E2E)
# E2E_CONFLICT_SLUG=jane-doe

# Optional: skip tests/sold-records-flow.spec.ts (e.g. CI without LLM keys / quota)
# E2E_SKIP_AI_STORY=1

# Optional: Supabase service role — lets sold-records-flow delete the test row by address after the run
# E2E_SUPABASE_SERVICE_ROLE_KEY=

# Optional: Playwright dev port / base URL (defaults: 3333 and http://127.0.0.1:3333)
# PLAYWRIGHT_DEV_PORT=3333
# PLAYWRIGHT_BASE_URL=http://127.0.0.1:3333

# Optional: AI sold story — put real keys in `.env.local` (gitignored) for `next dev` + generate-story; never commit secrets.
# GROQ_API_KEY=
# GROQ_MODEL=llama-3.3-70b-versatile
# GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
# GOOGLE_GENERATIVE_AI_API_KEY=
# GOOGLE_GENERATIVE_AI_MODEL=gemini-2.0-flash
# Legacy alias: GEMINI_API_KEY= / GEMINI_MODEL=
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
